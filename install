DOTFILES=$(cd $(dirname "${BASH_SOURCE[0]}") && pwd)

rm -rf $HOME/.oh-my-zsh/custom/aliases.zsh
ln -s $DOTFILES/zsh/aliases.zsh $HOME/.oh-my-zsh/custom/aliases.zsh

rm -rf $HOME/.zshrc
ln -s $DOTFILES/zsh/.zshrc $HOME/.zshrc

rm -rf $HOME/.config/nvim
ln -s $DOTFILES/nvim $HOME/.config/nvim

rm -rf $HOME/.config/zellij
ln -s $DOTFILES/zellij $HOME/.config/zellij

rm -rf $HOME/.config/alacritty
ln -s $DOTFILES/alacritty $HOME/.config/alacritty

rm -rf $HOME/.config/wezterm
ln -s $DOTFILES/wezterm $HOME/.config/wezterm

rm -rf $HOME/.config/kitty
ln -s $DOTFILES/kitty $HOME/.config/kitty

mkdir -p $HOME/.config/ghostty
rm -rf $HOME/.config/ghostty/config
ln -s $DOTFILES/ghostty/config $HOME/.config/ghostty/config

mkdir -p "$HOME/Library/Application Support/com.mitchellh.ghostty"
rm -rf "$HOME/Library/Application Support/com.mitchellh.ghostty/config"
ln -s "$DOTFILES/ghostty/config" "$HOME/Library/Application Support/com.mitchellh.ghostty/config"

rm -rf $HOME/.tmux.conf
ln -s $DOTFILES/tmux/.tmux.conf $HOME/.tmux.conf

echo 'successfully installed...'
